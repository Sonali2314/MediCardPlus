# Set default behavior to automatically normalize line endings
* text=auto

# Treat common text files as LF on checkout
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary

# Ensure git doesn't try to normalize node_modules
node_modules/** -diff
